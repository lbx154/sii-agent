LLM_BACKEND=vllm

# Azure OpenAI (AAD auth, no key needed — uses az login / DefaultAzureCredential)
AZURE_OPENAI_ENDPOINT=https://nikos-m6v5aj9v-eastus2.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# vLLM / SGLang (Qwen3.5-9B) — final benchmark backend
VLLM_BASE_URL=http://127.0.0.1:18877/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen/Qwen3.5-9B

# OPD / distillation expert (OpenAI-compatible Azure endpoint; put the real key in .env only)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPD_EXPERT_MODEL=gpt-5.4

# Search provider. web_search prefers the harness search-proxy; when SEARCH_PROXY_URL
# is empty, it can call Serper / Serper Lens directly with SERPER_API_KEY.
WIKI25_INDEX_PATH=data/wiki25/wiki25_fts.sqlite
BROWSECOMP_INDEX_PATH=indexes/bm25
BROWSECOMP_BM25_K1=10
BROWSECOMP_BM25_B=1

# Harness search-proxy (Serper + Jina on an internet-enabled host).
SEARCH_PROXY_URL=
SEARCH_PROXY_TOKEN=
SEARCH_PROXY_TIMEOUT=120
SEARCH_PROXY_FETCH=0
SEARCH_PROXY_MAX_CHARS=0
SEARCH_PROXY_VERIFY_SSL=true
SEARCH_PROXY_EXTRA_HEADERS=
SEARCH_PROXY_UPLOAD_TIMEOUT=120
SEARCH_PROXY_IMAGE_UPLOAD_RETRIES=2
SEARCH_PROXY_IMAGE_UPLOAD_BACKENDS=tmpfiles,catbox,proxy

# Direct Serper fallback used only when SEARCH_PROXY_URL is empty.
SERPER_API_KEY=
SERPER_TIMEOUT=30
SERPER_FETCH=0
SERPER_MAX_CHARS=0
JINA_API_KEY=
JINA_TIMEOUT=45

# Agent memory/self-retrieval.
SII_AGENT_MEMORY_ROOT=logs/memory
SII_AGENT_RUNTIME_MODE=train
BROWSER_EXTRACT_MAX_CHARS=12000

# Optional high-risk shell tool; disabled unless explicitly enabled and exposed by profile.
SII_AGENT_ENABLE_SHELL_TOOL=0
SII_AGENT_SHELL_ROOT=/root/sii-agent

# Optional browser backends.
# harness-sii-browser-service uses SANDBOX_BASE_URL and exposes /browser/cdp_url.
SANDBOX_BASE_URL=
SANDBOX_API_TOKEN=

# Optional All-in-One online sandbox browser backend.
# Start with:
# docker run --security-opt seccomp=unconfined --rm -it -p 8080:8080 ghcr.io/agent-infra/sandbox:latest
# Then set AIO_SANDBOX_BASE_URL=http://127.0.0.1:8080
AIO_SANDBOX_BASE_URL=
