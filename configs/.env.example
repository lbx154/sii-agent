LLM_BACKEND=vllm

# Azure OpenAI (AAD auth, no key needed — uses az login / DefaultAzureCredential)
AZURE_OPENAI_ENDPOINT=https://nikos-m6v5aj9v-eastus2.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# vLLM / SGLang (Qwen3.5-9B) — final benchmark backend
VLLM_BASE_URL=http://127.0.0.1:18877/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen/Qwen3.5-9B

# OPD / distillation expert (OpenAI-compatible Azure endpoint; put the real key in .env only)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPD_EXPERT_MODEL=gpt-5.4

# Search providers. Default C+D setup: DuckDuckGo online + offline wiki25.
SEARCH_BACKENDS=ddg,wiki
WIKI25_INDEX_PATH=data/wiki25/wiki25_fts.sqlite
BROWSECOMP_INDEX_PATH=data/browsecomp-plus/browsecomp_fts.sqlite

# Optional search providers
TAVILY_API_KEY=
SERPER_API_KEY=
