# 服务监听配置
HOST=0.0.0.0
PORT=8080

# 浏览器配置
HEADLESS=true
BROWSER_CDP_HOST=127.0.0.1
BROWSER_CDP_PORT=9222
DEFAULT_VIEWPORT_WIDTH=1280
DEFAULT_VIEWPORT_HEIGHT=800
BROWSER_BLOCK_RESOURCE_TYPES=

# Session 配置
MAX_SESSIONS=10
MAX_TABS_PER_SESSION=20
SESSION_IDLE_TIMEOUT=1800   # 30分钟无操作自动回收

# 鉴权（可选，留空则不鉴权）
API_TOKEN=
